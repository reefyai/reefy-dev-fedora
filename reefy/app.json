{
  "slug": "dev-fedora",
  "version": "45-2026.06.21-8",
  "name": "Dev Fedora",
  "icon": "/static/icons/dev-fedora.png",
  "description": "Fedora 45 development environment with systemd, KVM passthrough, and host /dev",
  "image": "ghcr.io/reefyai/reefy-dev-fedora:45-2026.06.21-8",
  "releases": [
    "ghcr.io/reefyai/reefy-dev-fedora:45-2026.06.21-8",
    "ghcr.io/reefyai/reefy-dev-fedora:45-2026.06.21-7",
    "ghcr.io/reefyai/reefy-dev-fedora:45-2026.06.20-6",
    "ghcr.io/reefyai/reefy-dev-fedora:45-2026.05.10-5",
    "ghcr.io/reefyai/reefy-dev-fedora:45-2026.05.09-4"
  ],
  "privileged": true,
  "gpu": true,
  "devices": [
    "/dev/kvm"
  ],
  "host_mounts": [
    "/dev:/dev",
    "/sys/fs/cgroup:/sys/fs/cgroup:rw"
  ],
  "tmpfs": [
    "/run",
    "/tmp:exec,mode=1777"
  ],
  "cgroupns": "host",
  "volumes": {
    "home": {
      "mount": "/root",
      "uid": 0,
      "backup": [
        "borgbase"
      ]
    },
    "build": {
      "mount": "/build",
      "uid": 0
    },
    "docker": {
      "mount": "/var/lib/docker",
      "uid": 0
    },
    "containerd": {
      "mount": "/var/lib/containerd",
      "uid": 0
    }
  },
  "env": {
    "SHELL": "/bin/bash"
  },
  "tags": [
    "dev"
  ]
}
